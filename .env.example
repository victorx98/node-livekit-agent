# LiveKit (not wired in Phase 0; required once the worker connects)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
GOOGLE_API_KEY=                 # used for Gemini realtime when not using Vertex AI
GEMINI_MODEL=gemini-3.1-flash-live-preview
GOOGLE_REALTIME_VOICE=          # unset => LiveKit Google plugin default (Puck)
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# AWS / S3 recording
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RECORDING_S3_BUCKET=            # falls back to S3_BUCKET for python-livekit-agent compatibility
S3_BUCKET=
RECORDING_REQUIRED=false        # wire has no per-job 'required'; env policy (§16)
RECORDING_AUDIO_ONLY=false

# Live state + transcript (REQUIRED from Phase 2 on)
REDIS_URL=redis://localhost:6379

# Final-state webhook target (no URL on the wire, §17)
WEBHOOK_URL=

# Agent identity (explicit dispatch target; §6)
AGENT_NAME=interview-agent

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=    # OTLP/HTTP base URL; unset => telemetry disabled (§20)
SERVICE_NAME=livekit-ai-interview-agent
NODE_ENV=production
LOG_LEVEL=info

# Monitoring API (§20) — separate port from the framework health server (8081)
MONITORING_PORT=8080
MONITORING_HOST=0.0.0.0

# Concurrency + lifecycle
MAX_CONCURRENT_INTERVIEWS=8     # per-worker hard cap (§18)
NUM_IDLE_PROCESSES=3            # prewarm pool, NOT a concurrency cap
DRAIN_TIMEOUT_SECONDS=3900      # prod: > max interview; dev/staging: small (§19)

# Provider gating
# Both OpenAI and Google realtime are enabled per-job from dispatch metadata.
GEMINI_MAX_MINUTES=10           # cap while long-session behavior is verified

# Webhook (simple retry only in MVP)
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BASE_MS=1000

# Reconnect/reseed (§13): fresh-session attempts after a fatal session failure
RECONNECT_MAX_RETRIES=3

# Realtime tuning (not on the wire; §8.3)
DEFAULT_VOICE=marin             # legacy OpenAI voice fallback; prefer OPENAI_REALTIME_VOICE
TURN_DETECTION=semantic_vad
SILENCE_DURATION_MS=700
INTERRUPT_RESPONSE=true
THINKING_LEVEL=minimal
