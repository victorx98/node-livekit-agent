{
  "name": "livekit-ai-interview-agent",
  "version": "0.0.0",
  "private": true,
  "description": "LiveKit AI Interview Agent Service (Phase 0 — skeleton + config contract)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --env-file=.env dist/main.js dev",
    "start": "node dist/main.js start",
    "dispatch": "node --env-file=.env scripts/dispatch.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@livekit/agents": "^1.4.4",
    "@livekit/agents-plugin-openai": "^1.4.4",
    "@livekit/rtc-node": "^0.13.29",
    "livekit-server-sdk": "^2.15.4",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
