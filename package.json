{
  "name": "livekit-ai-interview-agent",
  "version": "0.0.0",
  "private": true,
  "description": "LiveKit AI Interview Agent Service (Phase 0 — skeleton + config contract)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --env-file=.env dist/main.js dev",
    "start": "node dist/main.js start",
    "dispatch": "node --env-file=.env scripts/dispatch.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "harness:check": "node scripts/harness-check.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm harness:check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@google/genai": "1.52.0",
    "@livekit/agents": "^1.5.1",
    "@livekit/agents-plugin-google": "1.5.1",
    "@livekit/agents-plugin-openai": "^1.5.1",
    "@livekit/rtc-node": "^0.13.31",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "ioredis": "^5.11.0",
    "livekit-server-sdk": "^2.17.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "ioredis-mock": "^8.13.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
